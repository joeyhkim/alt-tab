{
  "manifest_version": 3,
  "name": "Alt Tab",
  "version": "1.1.0",
  "description": "Switch between recent tabs and manage shortcut URL redirects.",
  "key": "",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Alt Tab menu",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {},
    "switch-to-previous-tab": {
      "description": "Switch to the other recent tab"
    }
  }
}
